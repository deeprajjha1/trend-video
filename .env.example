# ─── AI Provider (pick ONE) ───────────────────────────────────────
# Switch between OpenAI (paid) and Ollama (free/local) by changing AI_PROVIDER.
# Only ONE line change needed to swap.

AI_PROVIDER=openai              # "openai" (paid) or "ollama" (free, local)
# AI_PROVIDER=ollama            # ← uncomment this and comment line above for free mode

# OpenAI settings (only needed if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Ollama settings (only needed if AI_PROVIDER=ollama)
# AI_MODEL=qwen2.5:14b          # Recommended: qwen2.5:14b (good quality, ~10GB RAM)
# AI_MODEL=qwen2.5:7b           # Lighter: qwen2.5:7b (~5GB RAM)
# AI_MODEL=qwen2.5:32b          # Best: qwen2.5:32b (~20GB RAM)
# AI_MODEL=llama3.1:8b          # Alternative: Llama 3.1 8B

# Advanced: override the base URL or model for any provider
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=gpt-4o

# ─── Optional APIs ───────────────────────────────────────────────

# YouTube Data API v3 key (enables channel URL input)
# Without this, you can still paste individual video URLs
YOUTUBE_API_KEY=your-youtube-api-key-here

# Pexels API key for free b-roll video clips (Step 10)
# Get a free key at: https://www.pexels.com/api/new/
PEXELS_API_KEY=your-pexels-api-key-here

# ─── Instagram Publishing (optional) ─────────────────────────────
# Enables direct Reel publishing to Instagram
# Get these from https://developers.facebook.com → Graph API Explorer
# INSTAGRAM_ACCESS_TOKEN=your-long-lived-access-token
# INSTAGRAM_ACCOUNT_ID=your-instagram-business-account-id

# Server port (default: 3000)
PORT=3000
